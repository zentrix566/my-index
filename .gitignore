# 所有以点(.)开头的目录都不提交（隐藏目录，如 .workbuddy/.vscode/.idea/.zcode/.build-tmp 等）
# 注：.git 目录由 git 自身管理，不受此规则影响
**/.*/

# DevOps Actions directory
devops-actions/

# Node.js
node_modules/
dist/
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Docker
*.tar
*.log

# IDE
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# ZCode local config
k8s/cloudflared-deployment.yaml

# 构建中间产物（验证用，可手动删除）
dist-old/

# SQLite 数据库（运行时数据，不入库；种子文件 server/seed/ 保留跟踪）
data/app.db
data/app.db-wal
data/app.db-shm
server/seed/*.local.json

# Windows 保留设备名误生成的垃圾文件，永不入库
nul

