# 所有以点(.)开头的目录都不提交（隐藏目录，如 .workbuddy/.vscode/.idea/.zcode/.build-tmp 等）
# 注：.git 目录由 git 自身管理，不受此规则影响；.github 必须提交以启用 CI。
**/.*/
!.github/

# DevOps Actions directory
devops-actions/

# Node.js
node_modules/
dist/
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# 环境变量（含密钥，绝不入库；仅 .env.example 可跟踪）
.env
.env.*
!.env.example

# Docker
*.tar
*.log

# IDE
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# ZCode local config
k8s/cloudflared-deployment.yaml

# 构建中间产物（验证用，可手动删除）
dist-old/

# 炉石卡牌图片：已迁移至阿里云 OSS，由服务端反代 /hearthstone-cards/ 提供，不进 git 版本库。
# CI 通过 .dockerignore 排除该目录（详见 .gitattributes，已声明不再走 Git LFS）；本地文件仅作 OSS 上传源保留。
src/hearthstone-achievements/assets/cards/

# SQLite 数据库（运行时数据，不入库；种子文件 server/seed/ 保留跟踪）
data/app.db
data/app.db-wal
data/app.db-shm
server/seed/*.local.json

# 数据库导出中间产物（含用户密码哈希等敏感数据，绝不入库）
server/remote-data/

# Windows 保留设备名误生成的垃圾文件，永不入库
nul

# Windows 保留设备名误生成的垃圾文件，永不入库
nul
