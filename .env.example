# Node.js 运行环境（development / production）
NODE_ENV=development

# 仅供本地登录和进度验证；true 时使用进程内存，不连接 PostgreSQL
LOCAL_DEV_MODE=false

# 服务端口
PORT=3000

# 访问日志存储目录（默认 ./logs）
LOG_DIR=./logs

# JWT 签名密钥；生产环境必须替换为随机长字符串
JWT_SECRET=your-random-jwt-secret-here

# PostgreSQL 连接配置
PG_HOST=127.0.0.1
PG_PORT=5432
PG_USER=postgres
PG_DATABASE=zentrix
PG_PASS=your-postgresql-password-here
PG_SSL=false

# 首次启动时创建所有者账号并导入示例进度
SEED_ON_STARTUP=false
OWNER_USERNAME=owner
OWNER_PASSWORD=your-owner-password-here

# AI 建议（实验功能）：DeepSeek Key 仅服务端使用，前端不接触
# 地址/模型固定为 https://api.deepseek.com/v1 + deepseek-v4-flash，无需配置
DEEPSEEK_API_KEY=your-deepseek-api-key-here
# 每日额度（可选，默认 5 次固定问答 + 1 次自由提问）
AI_FIXED_DAILY=5
AI_FREE_DAILY=1

# 炉石卡牌图（卡组详情）前端基地址。
# 留空（推荐）：前端用相对路径 /hearthstone-cards/...，图片以本站域名开头，
#   由服务端 /hearthstone-cards/* 反向代理到下方 OSS_ORIGIN（无需给 OSS 绑自定义域名/备案）。
# 也可填一个已备案的绝对地址（如 https://cdn.example.com），前端将直连该地址（不带结尾斜杠）。
VITE_OSS_BASE=

# 服务端反向代理的真实 OSS 源站（公开读）。/hearthstone-cards/* 的请求会被代理到这里，
# 并强制以 inline 方式返回图片（右键「在新标签打开图片」直接查看而非下载）。
# 格式：https://<bucket>.oss-cn-<真实region>.aliyuncs.com  （例如 beijing，务必替换占位符，不带结尾斜杠）
OSS_ORIGIN=https://your-bucket.oss-cn-beijing.aliyuncs.com

